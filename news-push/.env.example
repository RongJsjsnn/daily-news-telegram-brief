# 基础配置
TIMEZONE=Asia/Shanghai
SCHEDULE_HOUR=8
SCHEDULE_MINUTE=0
LOOKBACK_HOURS=24
ITEMS_PER_SECTION=3
MIN_ITEMS_PER_SECTION=2
REQUEST_TIMEOUT=12
REQUEST_RETRIES=3
RETRY_BACKOFF_SECONDS=1.5
MILITARY_FILTER_ENABLED=true

# 推送渠道：file / wecom / telegram / smtp
NOTIFIER=file
OUTPUT_DIR=./output
LOG_DIR=./logs

# 企业微信机器人
WECOM_WEBHOOK_URL=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 邮件 SMTP
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_USE_SSL=true

# 自动清理：每 15 天运行一次时，默认只删除超过 15 天的旧简报和超过 60 天的旧日志。
CLEANUP_BRIEF_RETENTION_DAYS=15
CLEANUP_LOG_RETENTION_DAYS=60

# 可选：覆盖默认 RSS。格式为 JSON 数组。
# RSS_FEEDS_JSON=[{"name":"BBC中文","url":"https://feeds.bbci.co.uk/zhongwen/simp/rss.xml","category_hint":"international","reliability":0.88}]
